datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  
  // Custom VTU fields
  phone         String?         @unique
  password      String?         // Optional because of OAuth
  walletBalance Float           @default(0.0)
  role          Role            @default(USER)
  isSuspended   Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  transactions  WalletTransaction[]
  airtime       AirtimePurchase[]
  data          DataPurchase[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
}

model WalletTransaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Float
  type      TxType
  reference String   @unique
  status    TxStatus
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

enum TxType {
  CREDIT
  DEBIT
}

enum TxStatus {
  PENDING
  SUCCESS
  FAILED
}

model AirtimePurchase {
  id                String   @id @default(cuid())
  userId            String
  network           String
  phone             String
  amount            Float
  reference         String   @unique
  status            TxStatus
  providerReference String?
  createdAt         DateTime @default(now())

  user              User     @relation(fields: [userId], references: [id])
}

model DataPurchase {
  id                String   @id @default(cuid())
  userId            String
  network           String
  plan              String
  phone             String
  amount            Float
  reference         String   @unique
  status            TxStatus
  providerReference String?
  createdAt         DateTime @default(now())

  user              User     @relation(fields: [userId], references: [id])
}

model Provider {
  id           String   @id @default(cuid())
  providerName String
  apiKey       String
  baseUrl      String
  status       Boolean  @default(true)
}
